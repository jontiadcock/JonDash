// Prisma schema for the secure per-user services dashboard.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  PENDING_SETUP
  ACTIVE
  DISABLED
}

model User {
  id       String     @id @default(cuid())
  email    String     @unique
  role     Role       @default(USER)
  status   UserStatus @default(PENDING_SETUP)

  // Set during account setup.
  passwordHash String?

  // TOTP secret, encrypted at rest (AES-256-GCM). Never store in plaintext.
  totpSecretEnc String?
  mfaEnabled    Boolean @default(false)

  // One-time setup token (stored hashed) handed to the user by the admin.
  setupTokenHash      String?   @unique
  setupTokenExpiresAt DateTime?

  // Brute-force protection.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  links    Link[]
  auditLogs AuditLog[]
  backupCodes BackupCode[]

  // Roles (named service bundles) assigned to this user.
  serviceRoles ServiceRole[] @relation("UserServiceRoles")

  // Access roles (named bundles of admin capabilities) assigned to this user.
  // Delegates admin powers without granting the full ADMIN role.
  accessRoles AccessRole[] @relation("UserAccessRoles")

  @@index([status])
}

// A named bundle of admin capabilities (permissions). Assigning an access role
// to a USER lets them perform specific admin actions without being a full ADMIN.
// permissionsJson is a JSON array of capability keys (see lib/auth/permissions.ts).
// Distinct from ServiceRole ("Service Groups"), which bundles services only.
model AccessRole {
  id              String @id @default(cuid())
  name            String @unique
  permissionsJson String @default("[]")

  users User[] @relation("UserAccessRoles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One-time 2FA recovery codes. The raw code is shown to the user once at
// generation; only its SHA-256 hash is stored. usedAt marks consumption.
model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// A named bundle of service tiles. Any user assigned this role sees its links.
model ServiceRole {
  id    String @id @default(cuid())
  name  String @unique

  users User[] @relation("UserServiceRoles")
  links Link[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Opaque session token, stored hashed (SHA-256). The raw token lives only in the cookie.
  tokenHash String   @unique

  expiresAt DateTime
  ip        String?
  userAgent String?
  // Coarse geo-location ("City, Country" / "Local network"), resolved best-effort
  // on first view of the sessions list. Null until resolved or if unavailable.
  location  String?
  // Last time this session was seen active (updated, throttled, on requests).
  lastSeenAt DateTime @default(now())
  // When TOTP was last verified on this session — powers step-up auth for major
  // destructive actions (fresh proof required within a short window).
  totpVerifiedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// A service tile. Belongs to EITHER a user (personal tile) or a role (shared
// tile) — exactly one of userId / roleId is set (enforced in application code).
model Link {
  id        String   @id @default(cuid())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  roleId    String?
  role      ServiceRole? @relation(fields: [roleId], references: [id], onDelete: Cascade)

  title     String
  url       String
  // Filename (random) of the stored icon under uploads/icons; served via /api/icons/[id].
  iconPath  String?
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, sortOrder])
  @@index([roleId, sortOrder])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  action    String
  ip        String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

// Typed key/value configuration store. Scope is "global" (ownerId ""), or later
// "user"/"module" (ownerId = userId/moduleKey). valueJson is JSON-encoded; when
// `secret` is set it is encrypted at rest (AES-256-GCM) via lib/crypto.
model Setting {
  id        String   @id @default(cuid())
  scope     String   @default("global")
  ownerId   String   @default("")
  key       String
  valueJson String
  secret    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, ownerId, key])
}
