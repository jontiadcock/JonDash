// Prisma schema for the secure per-user services dashboard.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  PENDING_SETUP
  ACTIVE
  DISABLED
}

model User {
  id       String     @id @default(cuid())
  email    String     @unique
  role     Role       @default(USER)
  status   UserStatus @default(PENDING_SETUP)

  // Set during account setup.
  passwordHash String?

  // TOTP secret, encrypted at rest (AES-256-GCM). Never store in plaintext.
  totpSecretEnc String?
  mfaEnabled    Boolean @default(false)

  // One-time setup token (stored hashed) handed to the user by the admin.
  setupTokenHash      String?   @unique
  setupTokenExpiresAt DateTime?

  // Brute-force protection.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  links    Link[]
  auditLogs AuditLog[]
  backupCodes BackupCode[]

  // Roles (named service bundles) assigned to this user.
  serviceRoles ServiceRole[] @relation("UserServiceRoles")

  // Access roles (named bundles of admin capabilities) assigned to this user.
  // Delegates admin powers without granting the full ADMIN role.
  accessRoles AccessRole[] @relation("UserAccessRoles")

  @@index([status])
  moduleLayouts   ModuleLayout[]
}

// A named bundle of admin capabilities (permissions). Assigning an access role
// to a USER lets them perform specific admin actions without being a full ADMIN.
// permissionsJson is a JSON array of capability keys (see lib/auth/permissions.ts).
// Distinct from ServiceRole ("Service Groups"), which bundles services only.
model AccessRole {
  id              String @id @default(cuid())
  name            String @unique
  permissionsJson String @default("[]")

  users User[] @relation("UserAccessRoles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One-time 2FA recovery codes. The raw code is shown to the user once at
// generation; only its SHA-256 hash is stored. usedAt marks consumption.
model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// A named bundle of service tiles. Any user assigned this role sees its links.
model ServiceRole {
  id    String @id @default(cuid())
  name  String @unique

  users User[] @relation("UserServiceRoles")
  links Link[]
  modules Module[] @relation("ModuleServiceRoles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Opaque session token, stored hashed (SHA-256). The raw token lives only in the cookie.
  tokenHash String   @unique

  expiresAt DateTime
  ip        String?
  userAgent String?
  // Coarse geo-location ("City, Country" / "Local network"), resolved best-effort
  // on first view of the sessions list. Null until resolved or if unavailable.
  location  String?
  // Last time this session was seen active (updated, throttled, on requests).
  lastSeenAt DateTime @default(now())
  // When TOTP was last verified on this session — powers step-up auth for major
  // destructive actions (fresh proof required within a short window).
  totpVerifiedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// A service tile. Belongs to EITHER a user (personal tile) or a role (shared
// tile) — exactly one of userId / roleId is set (enforced in application code).
model Link {
  id        String   @id @default(cuid())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  roleId    String?
  role      ServiceRole? @relation(fields: [roleId], references: [id], onDelete: Cascade)

  title     String
  url       String
  // Filename (random) of the stored icon under uploads/icons; served via /api/icons/[id].
  iconPath  String?
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, sortOrder])
  @@index([roleId, sortOrder])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  action    String
  ip        String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

// Typed key/value configuration store. Scope is "global" (ownerId ""), or later
// "user"/"module" (ownerId = userId/moduleKey). valueJson is JSON-encoded; when
// `secret` is set it is encrypted at rest (AES-256-GCM) via lib/crypto.
model Setting {
  id        String   @id @default(cuid())
  scope     String   @default("global")
  ownerId   String   @default("")
  key       String
  valueJson String
  secret    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, ownerId, key])
}

// ---- Module framework (MOD-01) ----

// A module's installed state. The module's code lives in modules/<id>/; this row
// tracks whether it's enabled, the permissions the admin granted at install (JSON
// array of ModulePermission), and the module version its migrations were applied for.
model Module {
  id                 String   @id // the module's stable id = its folder name
  name               String
  version            String
  enabled            Boolean  @default(false)
  source             String   @default("bundled") // repo URL, or "imported"/"bundled"
  // Per-module release channel ("stable" | "beta") — deliberately separate from the
  // app's own update channel, so a user can opt ONE module into beta releases.
  channel            String   @default("stable")
  // Opt-in automatic updates, PER MODULE and off by default. Deliberately not a single
  // global switch: one tick would hand every source — including any public repo added by
  // URL — a standing channel to run new code here. You opt in to the modules you trust.
  // An update that ADDS a permission is never auto-applied; it waits for approval.
  autoUpdate         Boolean  @default(false)
  grantedPermissions String   @default("[]")
  migratedVersion    String?
  // Service Groups this module is limited to. EMPTY = visible to every signed-in user
  // (its previous behaviour); assigning groups restricts it to their members. Admins
  // always see it. Mirrors how service tiles are shared.
  roles              ServiceRole[] @relation("ModuleServiceRoles")
  installedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// A module SOURCE: a public git repo publishing an `addons.json` manifest per channel
// branch (main = stable, beta = beta). The official JonDash-addons repo is seeded as
// the default source; admins can add their own by URL, or disable/remove any of them.
model ModuleSource {
  id        String   @id @default(cuid())
  name      String
  url       String   @unique // repo URL, e.g. https://github.com/jontiadcock/JonDash-addons
  enabled   Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Generic per-module key/value store (no bespoke table needed). Secret rows are
// encrypted at rest via lib/crypto.
model ModuleRecord {
  id        String   @id @default(cuid())
  moduleId  String
  key       String
  valueJson String
  secret    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, key])
  @@index([moduleId])
}

// Tracks which of a module's raw-SQL migrations (modules/<id>/migrations/*.sql) have
// been applied. The tables they create are namespaced mod_<id>_* and dropped on uninstall.
model ModuleMigration {
  id        String   @id @default(cuid())
  moduleId  String
  filename  String
  appliedAt DateTime @default(now())

  @@unique([moduleId, filename])
  @@index([moduleId])
}

/// Per-user dashboard layout for a module's widget (MOD-04 groundwork): each user sizes
/// and orders module widgets for themselves, so one person's arrangement never changes
/// anyone else's. Absent row = the module's default size at the end of the list.
model ModuleLayout {
  id        String @id @default(cuid())
  userId    String
  moduleId  String
  /// Width in dashboard grid columns (1 = compact, up to 4 = full width).
  width     Int    @default(1)
  /// Height in grid rows (1 = standard, larger = taller).
  height    Int    @default(1)
  /// Position on the dashboard; lower sorts first.
  sortOrder Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
}

/// An installed helper (MOD-08). Helpers are FIRST-PARTY ONLY — installable solely from
/// the official source — which is what makes it safe for them to do the privileged work
/// modules are forbidden (filesystem, process spawning, raw sockets). Kept in its own
/// table rather than reusing Module so helpers can never leak into module lists, RBAC or
/// the dashboard: they have no UI of their own and are not user-installable.
model Helper {
  id          String   @id // stable lowercase-kebab slug = its folder name
  name        String
  version     String
  /// Capabilities it provides, as a JSON array of permission keys (may be empty).
  providesJson String  @default("[]")
  migratedVersion String?
  /// The channel this helper is currently ON. Normally DERIVED, not chosen: a helper
  /// follows the highest channel among the modules that depend on it, so if any dependent
  /// is on beta the helper is too. That is only safe because a helper never breaks its own
  /// API, so a newer helper always satisfies an older consumer — and it replaces the old
  /// last-write-wins behaviour, where the version flipped depending on which module was
  /// touched most recently.
  channel     String   @default("stable")
  /// An explicit admin pin that overrides the derived channel ("stable" | "beta"), for
  /// taking a fix early or backing one out. Null = derived. Kept separate from `channel`
  /// so removing the pin restores the derived value rather than freezing the last one.
  channelPin  String?
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
