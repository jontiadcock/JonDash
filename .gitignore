# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# installed helpers (first-party, but installed from the official source like a module —
# not shipped in the app). lib/helpers/generated.ts IS committed, same as modules.
/helpers/*
!/helpers/.gitkeep

# installed add-on modules (user content — fetched from a source or imported, never
# shipped). lib/modules/generated.ts IS committed: it's regenerated from this folder at
# build time, and a stock checkout must typecheck with an empty registry.
/modules/*
!/modules/.gitkeep

# uploaded icons (user content), auto-generated secrets, and local sqlite database
/uploads
/.data
prisma/*.db
prisma/*.db-journal
prisma/*.db.*

# in-app "update & restart" sentinel handled by the launcher
/.update-and-restart
# in-app restart / shutdown signals handled by the supervisor
/.restart-and-run
/.shutdown

# verbose launcher/app action logs (local diagnostics only, never pushed)
/logs
# one-time auto-recovery marker written by the launcher
/.data/recovery-attempted

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
