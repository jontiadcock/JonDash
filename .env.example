# You normally do NOT need to create or edit this file — the app works out of
# the box. It is here only for advanced/hosted deployments.
#
# Database location (SQLite file, relative to the prisma/ directory):
DATABASE_URL="file:./dev.db"

# Optional: pin the encryption key instead of the auto-generated one in
# .data/secrets.json. Must be 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY="..."
